# Copy to .env on the server only. Do not commit real secrets.

# Official Twenty image tag. Pin versions for production; do not blindly track latest.
TAG=latest

# Public URL users and webhooks will use.
SERVER_URL=https://crm.murfreesborohomepros.com

# Single workspace is the intended MHP launch mode.
IS_MULTIWORKSPACE_ENABLED=false
IS_CONFIG_VARIABLES_IN_DB_ENABLED=true

# Generate on server: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_WITH_OPENSSL_RAND_BASE64_32

# Strong password without shell-hostile special chars if following Twenty docs exactly.
PG_DATABASE_PASSWORD=REPLACE_WITH_STRONG_POSTGRES_PASSWORD
